{
    "compilerOptions": {
        "declaration": true,
        "emitDeclarationOnly": true,
        "erasableSyntaxOnly": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "outDir": "./dist/",
        "rootDir": "./src/",
        "skipLibCheck": true,
        "strict": true,
        "target": "esnext",
        "types": ["bun"]
    }
}
