{
    "name": "@_apparatus_/fetch-tools",
    "description": "A thin wrapper for `fetch` with an `axios` inspired API.",
    "version": "3.1.3",
    "type": "module",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/pedro00dk/apparatus-fetch-tools"
    },
    "author": {
        "name": "Pedro Henrique",
        "email": "pedro00dk@gmail.com"
    },
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "keywords": [
        "fetch",
        "client",
        "request",
        "response",
        "http",
        "api",
        "rest",
        "get",
        "url",
        "axios",
        "node-fetch"
    ],
    "dependencies": {
        "hotscript": "1.0.13"
    },
    "devDependencies": {
        "@types/bun": "1.3.12",
        "form-data": "4.0.5",
        "msw": "2.13.3",
        "typescript": "6.0.2"
    },
    "scripts": {
        "build": "tsc && bun build --outdir ./dist/ ./src/index.ts",
        "test": "bun test"
    }
}
